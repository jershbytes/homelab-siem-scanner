#!/bin/bash
set -e

echo "================================================================="
echo " Starting Homelab SIEM, Scanner & Hardening Orchestrator"
echo "================================================================="

# Function for simple Y/N prompts
ask_user() {
    while true; do
        read -p "$1 [y/n]: " yn
        case $yn in
            [Yy]* ) return 0;;
            [Nn]* ) return 1;;
            * ) echo "Please answer yes or no.";;
        esac
    done
}

# 1. System Requirement Validation
TOTAL_RAM=$(free -g | awk '/^Mem:/{print $2}')
if [ "$TOTAL_RAM" -lt 4 ]; then
    echo "[!] WARNING: Wazuh and its database require at least 4GB of RAM."
    echo "    Current system has ${TOTAL_RAM}GB. Performance might suffer."
fi

# 2. Optional Firewall Hardening via UFW
if ask_user "[?] Would you like to enable the zero-trust UFW firewall baseline?"; then
    echo "[*] Configuring local network isolation baseline (UFW)..."
    sudo ufw default deny incoming
    sudo ufw default allow outgoing
    sudo ufw allow 22/tcp comment 'SSH Management'
    sudo ufw allow 443/tcp comment 'Wazuh Dashboard HTTPS'
    sudo ufw allow 1514/tcp comment 'Wazuh Agent Communication'
    sudo ufw allow 1515/tcp comment 'Wazuh Agent Registration'
    sudo ufw --force enable
else
    echo "[+] Skipping UFW firewall configuration."
fi

# 3. Optional ClamAV Initialization
if ask_user "[?] Would you like to initialize ClamAV local malware signatures?"; then
    echo "[*] Initializing ClamAV local signature engine..."
    sudo systemctl stop clamav-freshclam || true
    sudo freshclam || echo "[!] Signature update busy or offline, skipping..."
    sudo systemctl start clamav-freshclam || true
else
    echo "[+] Skipping ClamAV optimization."
fi

# 4. Optional Nmap Scan Alert Hook
if ask_user "[?] Would you like to verify that Nmap is available for vulnerability scanning?"; then
    if command -v nmap &> /dev/null; then
        echo "[+] Nmap binary verified at $(which nmap)."
    else
        echo "[!] Nmap not found. You can install it manually via 'sudo apt install nmap'."
    fi
else
    echo "[+] Skipping Nmap verification."
fi

# 5. Mandatory Bootstrap of the Official All-In-One Wazuh Stack
echo ""
echo "[*] Deploying Core Stack: Wazuh Manager & Indexer Stack (Mandatory)..."
curl -sO https://wazuh.com
sudo bash wazuh-install.sh -a

echo "================================================================="
echo " SIEM Pipeline and Scanner Deployment Completed!"
echo " Review the administrator credentials generated above by Wazuh."
echo "================================================================="
