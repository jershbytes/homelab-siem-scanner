#!/bin/sh
set -e

if [ "$1" = "configure" ]; then
    echo "========================================================="
    echo "       DEPLOYING SIEM: WAZUH + INTERNAL ELK PLATFORM     "
    echo "========================================================="

    # Dynamically detect binding interface (Prefers Tailscale, falls back to local primary IP)
    BIND_IP=$(tailscale ip -4 2>/dev/null || hostname -I | awk '{print $1}')

    # 1. Install Wazuh and its integrated ELK/OpenSearch components
    if ! command -v wazuh-manager >/dev/null 2>&1; then
        echo "[+] Fetching unified Wazuh/ELK deployment engine..."
        curl -sO https://packages.wazuh.com/4.x/wazuh-install.sh
        
        echo "[+] Running silent all-in-one SIEM cluster initialization (This takes ~5-10 mins)..."
        bash wazuh-install.sh -a --silent

        # 2. Prevent unattended-upgrades from breaking the SIEM layout
        echo "[+] Applying version pinning policies for Wazuh and ELK components..."
        mkdir -p /etc/apt/preferences.d
        
        cat << 'EOF' > /etc/apt/preferences.d/homelab-siem-pinning
# Pin Wazuh components to the current major.minor branch to prevent breaking upgrades
Package: wazuh-manager wazuh-indexer wazuh-dashboard
Pin: version 4.x*
Pin-Priority: 1001

# Pin OpenSearch/Elastic components if managed via the Wazuh stack
Package: opensearch opensearch-dashboards
Pin: version *
Pin-Priority: 1001
EOF
        echo "[+] Version pin successfully generated at /etc/apt/preferences.d/homelab-siem-pinning"
    fi

    # 3. Configure the Security Firewalls (Tailscale Perimeter Locked)
    echo "[+] Securing interfaces with localized UFW firewall rules..."
    ufw default deny incoming
    ufw allow from 100.0.0.0/8 to any port 22 proto tcp comment 'SSH over Tailscale'
    ufw allow from 100.0.0.0/8 to any port 443 proto tcp comment 'Wazuh Core UI (ELK Stack)'
    ufw allow from 100.0.0.0/8 to any port 1514 proto tcp comment 'Log Ingestion Engine'
    ufw reload

    echo "========================================================="
    echo " SUCCESS! Your SIEM Environment is deploying."
    echo " Access Core Interface: https://$BIND_IP"
    echo "========================================================="
fi

exit 0
